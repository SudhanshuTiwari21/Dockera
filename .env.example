# Razorpay (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional: create a Plan in Razorpay Dashboard (₹149/month) and set its ID here.
# If unset, the API will create a plan on first subscription.
# RAZORPAY_PLAN_ID=

# JWT for premium cookie (min 32 characters)
JWT_SECRET=

# Site URL for SEO (optional)
# NEXT_PUBLIC_SITE_URL=https://docera.com
